import pandas as pd
import numpy as np

def evaluate_candidates(df):
    """Calculates custom multipliers and builds clean text strings for vector mappings."""
    # Build text representation for vector spatial matching
    df['combined_text'] = (
        "Title: " + df['current_title'].fillna('') + " | " +
        "Skills: " + df['skills'].fillna('') + " | " +
        "Experience: " + df['years_of_experience'].astype(str) + " years"
    )
    
    # Calculate operational metric multipliers from behavioral footprints
    df['behavioral_multiplier'] = 1.0 + (
        df['redrob_signals.recruiter_response_rate'].fillna(0) * 0.1 + 
        df['redrob_signals.interview_completion_rate'].fillna(0) * 0.1
    )
    
    # Baseline placeholder scoring constants
    df['title_multiplier'] = 1.1
    df['exp_score'] = 1.0
    df['loc_score'] = 1.0
    
    return df
